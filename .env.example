# ===========================================
# Cancagua Web - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Application
# ===========================================
NODE_ENV=development
PORT=3000
VITE_APP_ID=cancagua

# ===========================================
# Authentication
# ===========================================
# Secret key for JWT tokens (generate a random string)
JWT_SECRET=your-secret-key-here

# Owner OpenID for admin access
OWNER_OPEN_ID=

# ===========================================
# Database - TiDB Cloud Serverless
# ===========================================
# Format: mysql://user:password@host/database
# Note: Do NOT include :4000 port or sslaccept parameter
DATABASE_URL=mysql://user:password@gateway01.region.prod.aws.tidbcloud.com/database_name

# ===========================================
# AI Services
# ===========================================
# Gemini API Key (for LLM functions)
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI API Key (optional - for Whisper transcription and DALL-E image generation)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ===========================================
# File Storage - Cloudinary
# ===========================================
# Option 1: Use CLOUDINARY_URL (recommended)
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://123456789012345:abcdefghijklmnop@your-cloud-name

# Option 2: Use individual variables
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=abcdefghijklmnop

# ===========================================
# Email Service - Resend
# ===========================================
# Get it from: https://resend.com/api-keys
RESEND_API_KEY=

# ===========================================
# External Integrations - Skedu
# ===========================================
SKEDU_APP_ID=
SKEDU_SECRET=
