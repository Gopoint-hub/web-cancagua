# ============================================
# Cancagua Frontend - Variables de Entorno
# ============================================
# Este repo es solo el frontend (SSR).
# Toda la logica de negocio (API, BD, WebPay, emails)
# vive en el CMS: cms.cancagua.cl

# Puerto del servidor SSR
PORT=3000

# URL de la API del CMS (donde vive el backend tRPC)
VITE_API_BASE_URL=https://cms.cancagua.cl

# Analytics (opcional)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=
